// npx prisma migrate dev --name <migration_name>  Run this command to update the database schema after making changes to this file.
// npx prisma generate  Run this command to regenerate the Prisma Client after making changes to this file.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(STUDENT)
  classId      String?
  refreshToken String?
  createdAt    DateTime @default(now())

  // Relations
  class               Class?   @relation(fields: [classId], references: [id])
  teachingAssignments TeachingAssignment[] @relation("TeacherAssignments")
  attendance          Attendance[]
}

model Subject {
  id   String @id @default(uuid())
  name String

  assignments TeachingAssignment[]

  @@unique([name])
}

model Class {
  id   String @id @default(uuid())
  name String

  assignments TeachingAssignment[]
  students    User[]   

  @@unique([name])
}

model TeachingAssignment {
  id        String @id @default(uuid())
  teacherId String
  subjectId String
  classId   String

  teacher   User    @relation("TeacherAssignments", fields: [teacherId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])
  class     Class   @relation(fields: [classId], references: [id])

  attendance Attendance[]

  @@unique([subjectId, classId])
}

model Attendance {
  id           String   @id @default(uuid())
  studentId    String
  assignmentId String
  date         DateTime
  status       AttendanceStatus

  student      User               @relation(fields: [studentId], references: [id])
  assignment   TeachingAssignment @relation(fields: [assignmentId], references: [id])

  @@unique([studentId, assignmentId, date])
}