// npx prisma migrate dev --name <migration_name>  Run this command to update the database schema after making changes to this file.
// npx prisma generate  Run this command to regenerate the Prisma Client after making changes to this file.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid()) // Unique identifier for the user, generated as a UUID.
  email        String   @unique
  password     String
  name         String
  avatar       String?
  credits      Int      @default(20)
  refreshToken String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  projects     Project[]  //it is not an array column in the database.
  //it is needed to define the relation from the User model to the Project model, as each user can have multiple projects. 
  //This allows us to easily query a user's projects and manage the relationship between users and their projects in the database.
  projectLikes ProjectLike[]
}

model Project {
  id                 String   @id @default(uuid())
  name               String
  userId             String
  productName        String   
  productDescription String   @default("")
  userPrompt         String   @default("")
  aspectRatio        String   @default("9:16")
  targetLength       Int      @default(5)
  uploadedImages     String[]
  generatedImage     String   @default("")
  generatedVideo     String   @default("")
  isGenerating       Boolean  @default(false)
  isPublished        Boolean  @default(false)
  error              String   @default("")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectLikes ProjectLike[]
}

model ProjectLike {
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
}
